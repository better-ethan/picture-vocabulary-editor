{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "rootDir": "./src",
    "lib": ["es2022"],
    "module": "NodeNext",
    "target": "ES2022",
    "types": ["node"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "moduleResolution": "NodeNext",
    "sourceMap": true,
    "outDir": "dist",
    "paths": {
      "~/*": ["./src/*"]
    }
  }
}
